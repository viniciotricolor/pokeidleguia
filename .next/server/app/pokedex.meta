{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/pokedex/layout,_N_T_/pokedex/page,_N_T_/pokedex"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/pokedex/__PAGE__",
    "/pokedex",
    "/_index",
    "/_head"
  ]
}